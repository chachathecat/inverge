# Core AI Providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REVIEW_OS_OPENAI_MODEL=gpt-4.1-mini
INVERGE_SECOND_EXAM_AI_PROVIDER=mock
INVERGE_SECOND_EXAM_AI_TIMEOUT_MS=3500

# Supabase
# Real auth/session requires:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# Real user-level Postgres persistence additionally requires:
# - SUPABASE_SERVICE_ROLE_KEY
#
# Behavior summary:
# - all three set: real auth/session + real user-level persistence
# - URL + anon only: real auth/session, but server persistence is unavailable
# - values missing: demo-mode auth/session for local development only
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Closed alpha access
# Comma-separated allowlist. In production, only these emails can enter /app.
ALPHA_INVITE_EMAILS=
# Optional admin allowlist for /admin/alpha
ALPHA_ADMIN_EMAILS=

# App
NEXT_PUBLIC_APP_NAME=Inverge

# M418 Web Push
# Generate local development values with:
# npm.cmd run generate:vapid
# Keep NEXT_PUBLIC_VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY as a matching pair.
# VAPID_PRIVATE_KEY, SUPABASE_SERVICE_ROLE_KEY, and CRON_SECRET are server-only.
# Changing VAPID keys invalidates or requires replacing existing push subscriptions.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
CRON_SECRET=
